          <div {{#if blockId}}id="{{blockId}}" {{/if}}class="{{#if className}}{{className}}{{else}}card shadow-sm{{/if}}{{#if hidden}} generated-files-block{{/if}}">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                <h6 class="card-title mb-0">{{title}}</h6>
                <span {{#if countId}}id="{{countId}}" {{/if}}class="badge text-bg-secondary">{{files.length}}</span>
              </div>
              {{#if files.length}}
              <div {{#if contentId}}id="{{contentId}}" {{/if}}class="generated-files-list list-group">
{{> generatedFilesList files=files}}
              </div>
              {{else}}
              <div {{#if contentId}}id="{{contentId}}" {{/if}}class="small text-muted">{{emptyMessage}}</div>
              {{/if}}
            </div>
          </div>
