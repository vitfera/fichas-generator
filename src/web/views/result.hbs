      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="card shadow-sm mb-4">
            <div class="card-body text-center">
              <p class="result-summary-eyebrow text-uppercase text-muted fw-semibold mb-2">
                Fichas geradas
              </p>
              <h5 class="card-title mb-1 text-break">
                {{opportunity.name}}
              </h5>
              <p class="text-muted small mb-4">
                Oportunidade #{{opportunity.id}}
              </p>
              <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a href="{{zipUrl}}" class="btn btn-success">
                  Baixar todas as fichas (ZIP)
                </a>
                <a href="/" class="btn btn-secondary">
                  Voltar
                </a>
              </div>
            </div>
          </div>

{{> generatedFilesCard title="Arquivos gerados" files=files}}
        </div>
      </div>
